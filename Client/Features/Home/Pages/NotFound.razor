@page "/not-found"
@layout MainLayout
@inject NavigationManager Nav

<PageTitle>Dating App - Not Found</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudPaper Elevation="0" Class="auth-surface pa-8">
        <MudStack Spacing="4" AlignItems="AlignItems.Center">
            <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Large">
                <MudIcon Icon="@Icons.Material.Rounded.SearchOff" />
            </MudAvatar>
            <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 700;">
                Nothing here
            </MudText>
            <MudText Typo="Typo.body1"
                     Align="Align.Center"
                     Style="color: var(--mud-palette-text-secondary); max-width: 50ch;">
                Sorry, there's nothing at this address. The page may have moved, or
                you may have followed a stale link.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Rounded.Home"
                       OnClick="HandleClick">
                Go home
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private void HandleClick()
    {
        Nav.NavigateTo("/");
    }
}

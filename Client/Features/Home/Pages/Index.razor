@page "/"

<PageTitle>Dating App - Home</PageTitle>

<MudStack Spacing="6" Class="app-page">
    <MudPaper Elevation="0" Class="app-hero pa-8">
        <MudStack Spacing="3">
            <MudText Typo="Typo.overline" Color="Color.Primary">Welcome</MudText>
            <MudText Typo="Typo.h2" Class="font-weight-bold">
                Find your <span class="mud-primary-text">match</span>.
            </MudText>
            <MudText Typo="Typo.body1" Class="app-page-subtitle">
                A modern place to meet people, exchange messages, and build connections.
                Sign up in seconds &mdash; no clutter, no noise, just the good stuff.
            </MudText>

            <AuthorizeView Context="HeroAuth">
                <NotAuthorized>
                    <MudStack Row="true" Spacing="2" Class="mt-2 app-action-bar">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Rounded.PersonAdd"
                                   OnClick="OnRegister">
                            Create account
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Rounded.Login"
                                   OnClick="OnLogin">
                            Sign in
                        </MudButton>
                    </MudStack>
                </NotAuthorized>
                <Authorized>
                    <MudStack Row="true" Spacing="2" Class="mt-2 app-action-bar">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   Href="/members"
                                   EndIcon="@Icons.Material.Rounded.ArrowForward">
                            Browse members
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Size="Size.Large"
                                   Href="/messages"
                                   StartIcon="@Icons.Material.Rounded.ChatBubbleOutline">
                            Messages
                        </MudButton>
                    </MudStack>
                </Authorized>
            </AuthorizeView>
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="4">
        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <MudPaper Elevation="0" Class="app-card pa-5">
                <MudStack Spacing="2" Class="flex-grow-1">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Medium">
                        <MudIcon Icon="@Icons.Material.Rounded.People" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6">Discover members</MudText>
                    <MudText Typo="Typo.body2" Class="app-muted">
                        Browse profiles tailored to your preferences with rich photo galleries
                        and an easy filter for distance, age, and interests.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <MudPaper Elevation="0" Class="app-card pa-5">
                <MudStack Spacing="2" Class="flex-grow-1">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Medium">
                        <MudIcon Icon="@Icons.Material.Rounded.Favorite" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6">Curated lists</MudText>
                    <MudText Typo="Typo.body2" Class="app-muted">
                        Keep tabs on people you like and people who liked you back, neatly
                        organised in lists you control.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <MudPaper Elevation="0" Class="app-card pa-5">
                <MudStack Spacing="2" Class="flex-grow-1">
                    <MudAvatar Color="Color.Tertiary" Variant="Variant.Outlined" Size="Size.Medium">
                        <MudIcon Icon="@Icons.Material.Rounded.ChatBubbleOutline" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6">Real-time chat</MudText>
                    <MudText Typo="Typo.body2" Class="app-muted">
                        SignalR-powered messaging with presence so you know exactly who is
                        online and ready to talk.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

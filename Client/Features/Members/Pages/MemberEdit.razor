@page "/member/edit"
@attribute [Authorize]

<PageTitle>DatingApp - Edit Profile</PageTitle>

<section class="app-page">
    @if (_showError)
    {
        <MudAlert Severity="Severity.Error">@_errorText</MudAlert>
    }

    <MudPaper Elevation="0" Class="app-card pa-4">
        <div class="app-page-header">
            <div class="app-page-title-group">
                <MudText Typo="Typo.h3">Your Profile</MudText>
                <MudText Typo="Typo.body2" Class="app-page-subtitle">
                    Keep your profile details current to improve match quality.
                </MudText>
            </div>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       ButtonType="ButtonType.Submit"
                       form="editForm"
                       Disabled="@(_changesMade == false)">
                Save Changes
            </MudButton>
        </div>
        @if (_changesMade)
        {
            <MudAlert Class="mt-4" Severity="Severity.Info" Variant="Variant.Outlined">
                You have unsaved changes.
            </MudAlert>
        }
    </MudPaper>

    <MudGrid Justify="Justify.Center">

        <MudItem xs="12" md="4" lg="3">
            <MudCard Elevation="0" Class="app-card">
                <MudCardHeader>
                    <MudImage Class="img-thumbnail mx-auto"
                              Src="@MemberStateService.MainPhoto"
                              Alt="@MemberStateService.Member.KnownAs"
                              Style="border: 4px solid var(--mud-palette-surface);" />
                </MudCardHeader>
                <MudCardContent Class="mx-auto" Style="width: 90%; height: 90%; max-width: 100%;">
                    <MudText Class="font-weight-bold">Location:</MudText>
                    <MudText Class="mb-3">@MemberStateService.Member.City, @MemberStateService.Member.State</MudText>
                    <MudText Class="font-weight-bold">Age:</MudText>
                    <MudText Class="mb-3">@MemberStateService.Member.Age</MudText>
                    <MudText Class="font-weight-bold">Last active:</MudText>
                    <MudText Class="mb-3">@DateTime.Now.Subtract(MemberStateService.Member.LastActive).Humanize()</MudText>
                    <MudText Class="font-weight-bold">Member since:</MudText>
                    <MudText>@MemberStateService.Member.Created.ToLongDateString()</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            <MudTabs Elevation="6" Centered="true" Rounded="true" Color="Color.Primary">

                <MudTabPanel Text="@($"About {MemberStateService.Member.KnownAs}")">
                    <MudContainer Class="mt-5 px-0">
                        <EditForm id="editForm" Model="@_memberUpdate" @oninput="(e) => OnProfileUpdated(e)" OnValidSubmit="HandleValidSubmitAsync">
                            <DataAnnotationsValidator />

                            <MudGrid>
                                <MudItem xs="12">
                                    <MudTextField Class="mb-10"
                                                  T="string"
                                                  Label="Description"
                                                  Variant="Variant.Outlined"
                                                  @bind-Value="@_memberUpdate.Introduction"
                                                  Lines="6" />
                                    <ValidationMessage For="(() => _memberUpdate.Introduction)" />

                                    <MudTextField Class="mb-10"
                                                  T="string"
                                                  Label="Looking for"
                                                  Variant="Variant.Outlined"
                                                  @bind-Value="@_memberUpdate.LookingFor"
                                                  Lines="6" />
                                    <ValidationMessage For="(() => _memberUpdate.LookingFor)" />

                                    <MudTextField Class="mb-10"
                                                  T="string"
                                                  Label="Interests"
                                                  Variant="Variant.Outlined"
                                                  @bind-Value="@_memberUpdate.Interests"
                                                  Lines="6" />
                                    <ValidationMessage For="(() => _memberUpdate.Interests)" />

                                    <MudGrid>
                                        <MudItem xs="6">
                                            <MudTextField Class="mb-10"
                                                          T="string"
                                                          Label="City"
                                                          Variant="Variant.Outlined"
                                                          @bind-Value="@_memberUpdate.City" />
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudTextField Class="mb-10"
                                                          T="string"
                                                          Label="State"
                                                          Variant="Variant.Outlined"
                                                          @bind-Value="@_memberUpdate.State" />
                                        </MudItem>
                                    </MudGrid>

                                    <ValidationMessage For="(() => _memberUpdate.City)" />
                                    <ValidationMessage For="(() => _memberUpdate.State)" />
                                </MudItem>
                            </MudGrid>

                        </EditForm>
                    </MudContainer>
                </MudTabPanel>

                <MudTabPanel Text="Photos">
                    <MudContainer Class="mt-5 px-0">
                        <PhotoEditor OnImageChanged="ImageChangedCallbackAsync" />
                    </MudContainer>
                </MudTabPanel>

            </MudTabs>
        </MudItem>

    </MudGrid>
</section>

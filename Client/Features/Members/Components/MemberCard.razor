<div class="member-card-wrap">
    <MudCard Elevation="0" Class="app-card member-card">
        <MudCardHeader>
            <div class='img-blur-wrap'>
                <div class='img-blur-bg' style="background-image: linear-gradient(rgba(0, 0, 0, 0.3),rgba(0, 0, 0, 0.3) ), url('@_photoFilename');"></div>
                <div class='img-blur' style="background-image: url('@_photoFilename')"></div>
            </div>
        </MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="member-info d-flex justify-center align-center">
                @if (PresenceService.OnlineUsers.Contains(Member.Username))
                {
                    <MudIcon Class="mt-0 mr-1" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small"></MudIcon> @Member.KnownAs @($" | {Member.Age}")
                }
                else 
                {
                    @($"{Member.KnownAs} | {Member.Age}")
                }
            </MudText>
            <MudDivider DividerType="DividerType.Middle" />
            <MudText Typo="Typo.body1" Align="Align.Center" Class="member-location">
                @Member.City
            </MudText>
            <MudStack Row="true" Spacing="1" Class="member-icons pt-3">
                <MudIconButton Icon="@Icons.Material.Filled.Person"
                               Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Medium"
                               aria-label="Profile"
                               OnClick="HandleUserClick" />
                <MudIconButton Icon="@Icons.Material.Filled.Favorite"
                               Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Medium"
                               OnClick="HandleLikeToggleAsync"
                               aria-label="Like" />
                <MudIconButton Icon="@Icons.Material.Filled.Mail"
                               Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Medium"
                               OnClick="HandleMessageClick"
                               aria-label="Message" />
            </MudStack>
        </MudCardContent>
    </MudCard>
</div>

@page "/theme"

<PageTitle>Dating App - Theme</PageTitle>

<MudStack Spacing="6">

    <MudStack Spacing="1">
        <MudText Typo="Typo.overline"
                 Style="color: var(--mud-palette-primary); letter-spacing: 0.12em;">
            Design system
        </MudText>
        <MudText Typo="Typo.h3" Style="font-weight: 700;">Theme reference</MudText>
        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary); max-width: 70ch;">
            United-inspired orange and aubergine for light mode; GitHub-style soft dimmed
            surfaces for dark mode. Typography is set in Inter for UI text and JetBrains
            Mono for code.
        </MudText>
    </MudStack>

    @* ---------- Palette ---------- *@
    <MudStack Spacing="3">
        <MudText Typo="Typo.h5">Palette</MudText>
        <MudGrid Spacing="3">

            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="theme-swatch">
                    <div class="theme-swatch-main mud-theme-primary">
                        <MudText Typo="Typo.subtitle1">Primary</MudText>
                        <MudText Typo="Typo.caption">@(MudThemeProviderColor("primary"))</MudText>
                    </div>
                    <div class="theme-swatch-row">
                        <div class="theme-swatch-tone" style="background: var(--mud-palette-primary-lighten);">
                            <span>Lighten</span>
                        </div>
                        <div class="theme-swatch-tone" style="background: var(--mud-palette-primary-darken);">
                            <span>Darken</span>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="theme-swatch">
                    <div class="theme-swatch-main mud-theme-secondary">
                        <MudText Typo="Typo.subtitle1">Secondary</MudText>
                        <MudText Typo="Typo.caption">Rose</MudText>
                    </div>
                    <div class="theme-swatch-row">
                        <div class="theme-swatch-tone" style="background: var(--mud-palette-secondary-lighten);">
                            <span>Lighten</span>
                        </div>
                        <div class="theme-swatch-tone" style="background: var(--mud-palette-secondary-darken);">
                            <span>Darken</span>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="theme-swatch">
                    <div class="theme-swatch-main mud-theme-tertiary">
                        <MudText Typo="Typo.subtitle1">Tertiary</MudText>
                        <MudText Typo="Typo.caption">Teal</MudText>
                    </div>
                    <div class="theme-swatch-row">
                        <div class="theme-swatch-tone" style="background: var(--mud-palette-tertiary-lighten);">
                            <span>Lighten</span>
                        </div>
                        <div class="theme-swatch-tone" style="background: var(--mud-palette-tertiary-darken);">
                            <span>Darken</span>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="theme-swatch">
                    <div class="theme-swatch-main mud-theme-info">
                        <MudText Typo="Typo.subtitle1">Info</MudText>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="theme-swatch">
                    <div class="theme-swatch-main mud-theme-success">
                        <MudText Typo="Typo.subtitle1">Success</MudText>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="theme-swatch">
                    <div class="theme-swatch-main mud-theme-warning">
                        <MudText Typo="Typo.subtitle1">Warning</MudText>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="theme-swatch">
                    <div class="theme-swatch-main mud-theme-error">
                        <MudText Typo="Typo.subtitle1">Error</MudText>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Elevation="0" Class="theme-swatch">
                    <div class="theme-swatch-main mud-theme-dark">
                        <MudText Typo="Typo.subtitle1">Dark / Aubergine</MudText>
                        <MudText Typo="Typo.caption">United purple</MudText>
                    </div>
                    <div class="theme-swatch-row">
                        <div class="theme-swatch-tone" style="background: var(--mud-palette-dark-lighten); color: #fff;">
                            <span>Lighten</span>
                        </div>
                        <div class="theme-swatch-tone" style="background: var(--mud-palette-dark-darken); color: #fff;">
                            <span>Darken</span>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

        </MudGrid>
    </MudStack>

    @* ---------- Typography ---------- *@
    <MudStack Spacing="3">
        <MudText Typo="Typo.h5">Typography</MudText>
        <MudPaper Elevation="0" Class="app-card pa-6">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h1">Heading 1</MudText>
                <MudText Typo="Typo.h2">Heading 2</MudText>
                <MudText Typo="Typo.h3">Heading 3</MudText>
                <MudText Typo="Typo.h4">Heading 4</MudText>
                <MudText Typo="Typo.h5">Heading 5</MudText>
                <MudText Typo="Typo.h6">Heading 6</MudText>
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle1">Subtitle 1 &mdash; subdued lead text for sections</MudText>
                <MudText Typo="Typo.subtitle2">Subtitle 2 &mdash; smaller subdued lead text</MudText>
                <MudText Typo="Typo.body1">
                    Body 1 &mdash; the quick brown fox jumps over the lazy dog. 1234567890.
                </MudText>
                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                    Body 2 &mdash; secondary copy used for descriptions and helper text.
                </MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                    Caption &mdash; small print and metadata.
                </MudText>
                <MudText Typo="Typo.overline"
                         Style="color: var(--mud-palette-primary); letter-spacing: 0.12em;">
                    Overline &mdash; section labels
                </MudText>
            </MudStack>
        </MudPaper>
    </MudStack>

    @* ---------- Text utility colors ---------- *@
    <MudStack Spacing="3">
        <MudText Typo="Typo.h5">Text styles</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="0" Class="app-card pa-4">
                    <MudText Typo="Typo.h6" Class="mud-text-primary">Text primary</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-primary">
                        High-emphasis content.
                    </MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="0" Class="app-card pa-4">
                    <MudText Typo="Typo.h6" Class="mud-text-secondary">Text secondary</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        Medium-emphasis content.
                    </MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="0" Class="app-card pa-4">
                    <MudText Typo="Typo.h6" Class="mud-text-disabled">Text disabled</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-disabled">
                        Low-emphasis content.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudStack>

</MudStack>

@code {
    private static string MudThemeProviderColor(string token) => $"--mud-palette-{token}";
}

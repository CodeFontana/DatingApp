@page "/register"

<PageTitle>Dating App - Create account</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-4">
    <EditForm Model="@_registerUser" OnValidSubmit="OnRegisterAsync">
        <DataAnnotationsValidator />

        <MudPaper Elevation="0" Class="auth-surface pa-6 pa-sm-8">
            <MudStack Spacing="4">

                <MudStack Spacing="1" AlignItems="AlignItems.Center">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                        <MudIcon Icon="@Icons.Material.Rounded.PersonAdd" />
                    </MudAvatar>
                    <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 700;">
                        Create your account
                    </MudText>
                    <MudText Typo="Typo.body2"
                             Align="Align.Center"
                             Style="color: var(--mud-palette-text-secondary);">
                        It only takes a minute &mdash; tell us a little about yourself.
                    </MudText>
                </MudStack>

                <MudDivider />

                <MudStack Spacing="3">

                    <MudRadioGroup T="string"
                                   @bind-Value="_registerUser.Gender"
                                   Required="true"
                                   For="@(() => _registerUser.Gender)">
                        <MudStack Row="true" Spacing="4" Justify="Justify.Center">
                            <MudRadio T="string" Value="@("Female")" Color="Color.Primary">Female</MudRadio>
                            <MudRadio T="string" Value="@("Male")" Color="Color.Primary">Male</MudRadio>
                        </MudStack>
                    </MudRadioGroup>

                    <MudTextField Label="Username"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  @bind-Value="_registerUser.Username"
                                  For="@(() => _registerUser.Username)" />

                    <MudTextField Label="Email"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  InputType="InputType.Email"
                                  @bind-Value="_registerUser.Email"
                                  For="@(() => _registerUser.Email)" />

                    <MudTextField Label="Preferred name or nickname"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  @bind-Value="_registerUser.KnownAs"
                                  For="@(() => _registerUser.KnownAs)" />

                    <MudDatePicker Label="Birthdate"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   @bind-Date="_registerUser.DateOfBirth"
                                   ShowToolbar="false"
                                   For="@(() => _registerUser.DateOfBirth)" />

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Town or city"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          @bind-Value="_registerUser.City"
                                          For="@(() => _registerUser.City)" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="State or province"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          @bind-Value="_registerUser.State"
                                          For="@(() => _registerUser.State)" />
                        </MudItem>
                    </MudGrid>

                    <MudTextField Label="Password"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  @bind-Value="_registerUser.Password"
                                  For="@(() => _registerUser.Password)"
                                  InputType="@_passwordInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_passwordInputIcon"
                                  OnAdornmentClick="ToggleShowPassword"
                                  AdornmentAriaLabel="Show password" />

                    <MudTextField Label="Confirm password"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  @bind-Value="_registerUser.ConfirmPassword"
                                  For="@(() => _registerUser.ConfirmPassword)"
                                  InputType="@_passwordInput" />
                </MudStack>

                @if (_showError)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
                        @_errorText
                    </MudAlert>
                }

                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                    <MudButton ButtonType="ButtonType.Button"
                               Variant="Variant.Text"
                               Color="Color.Default"
                               OnClick="OnCancel">
                        Cancel
                    </MudButton>
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Rounded.PersonAdd">
                        Create account
                    </MudButton>
                </MudStack>

                <MudStack Row="true"
                          AlignItems="AlignItems.Center"
                          Justify="Justify.Center"
                          Spacing="1">
                    <MudText Typo="Typo.body2"
                             Style="color: var(--mud-palette-text-secondary);">
                        Already have an account?
                    </MudText>
                    <MudLink Href="/login" Typo="Typo.body2" Underline="Underline.Hover">
                        Sign in
                    </MudLink>
                </MudStack>

            </MudStack>
        </MudPaper>
    </EditForm>
</MudContainer>

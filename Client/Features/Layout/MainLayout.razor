@inherits LayoutComponentBase
@using Client.Features.Theme

<MudThemeProvider Theme="AppTheme.Default" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<Spinner />

<MudLayout Class="app-layout" Style="min-width: 350px;">

    <MudAppBar Elevation="0"
               Dense="true"
               Color="Color.Surface"
               Class="app-appbar"
               Style="border-bottom: 1px solid var(--mud-palette-divider);">

        <MudIconButton Icon="@Icons.Material.Rounded.Menu"
                       Color="Color.Default"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer"
                       Class="mr-1" />

        <MudLink Href="/"
                 Underline="Underline.None"
                 Color="Color.Inherit"
                 Class="app-brand">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Rounded.Favorite"
                         Color="Color.Primary"
                         Size="Size.Medium" />
                <MudText Typo="Typo.subtitle1"
                         Class="app-brand-text"
                         Style="white-space: nowrap;">
                    Dating App
                </MudText>
            </MudStack>
        </MudLink>

        <AuthorizeView Context="AppBarContext">
            <Authorized>
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center"
                              Class="app-appbar-nav ml-4">
                        <MudButton Href="/members"
                                   Variant="Variant.Text"
                                   Color="Color.Inherit"
                                   StartIcon="@Icons.Material.Rounded.People">
                            Members
                        </MudButton>
                        <MudButton Href="/lists"
                                   Variant="Variant.Text"
                                   Color="Color.Inherit"
                                   StartIcon="@Icons.Material.Rounded.FormatListBulleted">
                            Lists
                        </MudButton>
                        <MudButton Href="/messages"
                                   Variant="Variant.Text"
                                   Color="Color.Inherit"
                                   StartIcon="@Icons.Material.Rounded.ChatBubbleOutline">
                            Messages
                        </MudButton>
                        <AuthorizeView Context="AdminContext" Roles="Administrator,Moderator">
                            <MudButton Href="/admin"
                                       Variant="Variant.Text"
                                       Color="Color.Inherit"
                                       StartIcon="@Icons.Material.Rounded.Shield">
                                Admin
                            </MudButton>
                        </AuthorizeView>
                    </MudStack>
                </MudHidden>
            </Authorized>
        </AuthorizeView>

        <MudSpacer />

        <MudTooltip Text="@_themeTooltip" Arrow="true" Placement="Placement.Bottom">
            <MudIconButton Icon="@_themeIcon"
                           Color="Color.Default"
                           OnClick="ToggleThemeAsync" />
        </MudTooltip>

        <AuthorizeView Context="AccountContext">
            <Authorized>
                @if (MemberStateService.Member is not null)
                {
                    <MudMenu AnchorOrigin="Origin.BottomRight"
                             TransformOrigin="Origin.TopRight"
                             Dense="true">
                        <ActivatorContent>
                            <MudTooltip Text="Account" Arrow="true" Placement="Placement.Bottom">
                                <MudAvatar Style="cursor: pointer;"
                                           Class="ml-2"
                                           Size="Size.Small"
                                           @onclick="@(async e => await context.ToggleAsync(e))">
                                    <MudImage Src="@MemberStateService.MainPhoto" />
                                </MudAvatar>
                            </MudTooltip>
                        </ActivatorContent>
                        <ChildContent>
                            <MudStack Spacing="0" Class="px-4 py-2">
                                <MudText Typo="Typo.subtitle2">
                                    @(MemberStateService.Member.KnownAs ?? AccountContext.User.Identity?.Name ?? "Signed in")
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                                    @AccountContext.User.Identity?.Name
                                </MudText>
                            </MudStack>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Rounded.Edit"
                                         Href="/member/edit">
                                Edit profile
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Rounded.Logout"
                                         OnClick="HandleLogoutAsync">
                                Logout
                            </MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                }
            </Authorized>
            <NotAuthorized>
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="ml-2">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Inherit"
                                   StartIcon="@Icons.Material.Rounded.Login"
                                   Href="/login">
                            Sign in
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Rounded.PersonAdd"
                                   Href="/register">
                            Create account
                        </MudButton>
                    </MudStack>
                </MudHidden>
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <MudIconButton Icon="@Icons.Material.Rounded.Login"
                                   Color="Color.Default"
                                   Href="/login" />
                </MudHidden>
            </NotAuthorized>
        </AuthorizeView>

    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Never"
               Class="app-drawer">

        <MudDrawerHeader Class="app-drawer-header" Style="padding: 1.25rem 1.25rem 1rem;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Rounded.Favorite" Size="Size.Small" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle2"
                             Style="color: var(--mud-palette-drawer-text); font-weight: 600;">
                        Dating App
                    </MudText>
                    <MudText Typo="Typo.caption"
                             Style="color: var(--mud-palette-drawer-icon);">
                        @_environmentLabel
                    </MudText>
                </MudStack>
            </MudStack>
        </MudDrawerHeader>

        <MudDivider Class="mx-4 app-drawer-divider" />

        <div class="app-drawer-nav">

            <MudText Typo="Typo.overline"
                     Class="px-6 pt-4 pb-2 app-drawer-section">
                Navigation
            </MudText>

            <AuthorizeView Context="DrawerContext">

                <Authorized>
                    <MudNavMenu Class="px-2">
                        <MudNavLink Href="/"
                                    Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Rounded.Home"
                                    IconColor="Color.Inherit">
                            Home
                        </MudNavLink>
                        <MudNavLink Href="/members"
                                    Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Rounded.People"
                                    IconColor="Color.Inherit">
                            Members
                        </MudNavLink>
                        <MudNavLink Href="/lists"
                                    Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Rounded.FormatListBulleted"
                                    IconColor="Color.Inherit">
                            Lists
                        </MudNavLink>
                        <MudNavLink Href="/messages"
                                    Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Rounded.ChatBubbleOutline"
                                    IconColor="Color.Inherit">
                            Messages
                        </MudNavLink>
                        <AuthorizeView Context="AdminContext" Roles="Administrator,Moderator">
                            <MudNavLink Href="/admin"
                                        Match="NavLinkMatch.All"
                                        Icon="@Icons.Material.Rounded.Shield"
                                        IconColor="Color.Inherit">
                                Admin
                            </MudNavLink>
                        </AuthorizeView>
                    </MudNavMenu>

                    <MudText Typo="Typo.overline"
                             Class="px-6 pt-4 pb-2 app-drawer-section">
                        Account
                    </MudText>
                    <MudNavMenu Class="px-2">
                        <MudNavLink Href="/member/edit"
                                    Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Rounded.Edit"
                                    IconColor="Color.Inherit">
                            Edit profile
                        </MudNavLink>
                        <MudNavLink OnClick="HandleLogoutAsync"
                                    Icon="@Icons.Material.Rounded.Logout"
                                    IconColor="Color.Inherit">
                            Logout
                        </MudNavLink>
                    </MudNavMenu>
                </Authorized>

                <NotAuthorized>
                    <MudNavMenu Class="px-2">
                        <MudNavLink Href="/"
                                    Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Rounded.Home"
                                    IconColor="Color.Inherit">
                            Home
                        </MudNavLink>
                    </MudNavMenu>

                    <MudText Typo="Typo.overline"
                             Class="px-6 pt-4 pb-2 app-drawer-section">
                        Account
                    </MudText>
                    <MudNavMenu Class="px-2">
                        <MudNavLink Href="/login"
                                    Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Rounded.Login"
                                    IconColor="Color.Inherit">
                            Sign in
                        </MudNavLink>
                        <MudNavLink Href="/register"
                                    Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Rounded.PersonAdd"
                                    IconColor="Color.Inherit">
                            Create account
                        </MudNavLink>
                    </MudNavMenu>
                </NotAuthorized>

            </AuthorizeView>

            @if (HostEnv.IsDevelopment())
            {
                <MudText Typo="Typo.overline"
                         Class="px-6 pt-4 pb-2 app-drawer-section">
                    Developer
                </MudText>
                <MudNavMenu Class="px-2">
                    <MudNavLink Href="/verifyauth"
                                Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Rounded.Lock"
                                IconColor="Color.Inherit">
                        Verify auth
                    </MudNavLink>
                    <MudNavLink Href="/theme"
                                Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Rounded.Palette"
                                IconColor="Color.Inherit">
                        Theme
                    </MudNavLink>
                </MudNavMenu>
            }
        </div>

    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4 px-sm-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
